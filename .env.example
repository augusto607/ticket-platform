# -----------------------------
# Application
# -----------------------------
APP_NAME=ITBrain Platform
APP_ENV=development

# -----------------------------
# Database (PostgreSQL)
# -----------------------------
POSTGRES_DB=ticket_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Full database URL used by SQLAlchemy
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/ticket_db

# -----------------------------
# Security
# -----------------------------
SECRET_KEY=supersecretkey
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60